{
  "name": "sawa-server",
  "version": "0.1.0",
  "description": "SAWA — Couples Social Matching App — Backend API",
  "main": "dist/server.js",
  "scripts": {
    "dev": "lsof -ti:3000 | xargs kill -9 || true; ts-node-dev --respawn --transpile-only src/server.ts",
    "build": "tsc",
    "start": "pm2-runtime start dist/server.js -i 1",
    "seed": "ts-node src/scripts/seed.ts",
    "db:flush": "ts-node src/scripts/flushDB.ts",
    "lint": "eslint src --ext .ts",
    "lint:fix": "eslint src --ext .ts --fix",
    "test": "jest --runInBand",
    "test:watch": "jest --watch",
    "typecheck": "tsc --noEmit",
    "postinstall": "npx prisma generate && npm run build",
    "db:push": "npx prisma db push --accept-data-loss"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.1075.0",
    "@aws-sdk/s3-request-presigner": "^3.1075.0",
    "@prisma/client": "^6.19.2",
    "@socket.io/redis-adapter": "^8.3.0",
    "bcryptjs": "^2.4.3",
    "cloudinary": "^2.9.0",
    "compression": "^1.7.4",
    "cors": "^2.8.5",
    "dotenv": "^16.6.1",
    "express": "^4.19.2",
    "express-rate-limit": "^7.3.1",
    "firebase-admin": "^13.8.0",
    "helmet": "^7.1.0",
    "ioredis": "^5.10.1",
    "jsonwebtoken": "^9.0.2",
    "morgan": "^1.10.0",
    "multer": "^1.4.5-lts.1",
    "node-fetch": "^2.7.0",
    "openai": "^6.32.0",
    "pm2": "^6.0.14",
    "prisma": "^6.19.2",
    "socket.io": "^4.7.5",
    "twilio": "^5.13.1",
    "uuid": "^13.0.0",
    "winston": "^3.13.0",
    "winston-daily-rotate-file": "^5.0.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/compression": "^1.7.5",
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/jsonwebtoken": "^9.0.6",
    "@types/morgan": "^1.9.9",
    "@types/multer": "^1.4.13",
    "@types/node": "^20.19.37",
    "@types/node-fetch": "^2.6.13",
    "@types/twilio": "^3.19.2",
    "@types/uuid": "^10.0.0",
    "@types/webidl-conversions": "^7.0.3",
    "@types/whatwg-url": "^13.0.0",
    "@typescript-eslint/eslint-plugin": "^7.13.0",
    "@typescript-eslint/parser": "^7.13.0",
    "eslint": "^8.57.0",
    "jest": "^29.7.0",
    "supertest": "^7.0.0",
    "ts-jest": "^29.1.5",
    "ts-node-dev": "^2.0.0",
    "typescript": "^5.4.5"
  },
  "engines": {
    "node": ">=20.0.0"
  }
}
