generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id               String    @id @default(cuid()) @map("_id")
  phone            String?   @unique
  name             String?
  email            String?   @unique
  dob              String?
  coupleId         String?
  isPhoneVerified  Boolean   @default(false)
  refreshTokenHash String?
  role             UserRole  @default(primary)
  password         String?
  // Activity tracking — touched on every authenticated request.
  // Used by admin to surface "Inactive" status (no activity > N days).
  lastActiveAt     DateTime?
  // Push notification credentials. Captured by mobile app at login/permission grant.
  pushToken        String?
  pushPlatform     String?
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt
  partnerOf1       Couple[]  @relation("Partner1")
  partnerOf2       Couple[]  @relation("Partner2")
  messages         Message[] @relation("Message_senderUser")
  coupleProfile    Couple?   @relation("CouplePartners", fields: [coupleId], references: [coupleId])

  @@index([coupleId])
  @@index([lastActiveAt])
  @@map("users")
}

model Couple {
  id                    String                 @id @default(cuid()) @map("_id")
  coupleId              String                 @unique
  profileName           String?
  relationshipStatus    String?
  bio                   String?
  primaryPhoto          String?
  secondaryPhotos       String[]               @default([])
  locationCity          String?
  locationCountry       String?
  locationLatitude      Float?
  locationLongitude     Float?
  isProfileComplete     Boolean                @default(false)
  isSubscribed          Boolean                @default(false)
  isOpenToMeeting       Boolean                @default(true)
  meetingFrequency      String?
  socialVibes           String[]               @default([])
  activities            String[]               @default([])
  avoidances            String[]               @default([])
  matchCriteria         String[]               @default([])
  blocked               String[]               @default([])
  // Admin-controlled ban. When set, both partners are blocked from logging in
  // and re-establishing sessions (existing tokens are rejected by middleware).
  bannedAt              DateTime?
  banReason             String?
  createdAt             DateTime               @default(now())
  updatedAt             DateTime               @updatedAt
  partner1Id            String?
  partner2Id            String?
  communityAdmins       CommunityAdmin[]
  communityRequests     CommunityJoinRequest[]
  communityMembers      CommunityMember[]
  partner1              User?                  @relation("Partner1", fields: [partner1Id], references: [id])
  partner2              User?                  @relation("Partner2", fields: [partner2Id], references: [id])
  matchActions          Match[]                @relation("Match_actionBy")
  match1                Match[]                @relation("Match_couple1")
  match2                Match[]                @relation("Match_couple2")
  sentMessages          Message[]              @relation("Message_sender")
  receivedNotifications Notification[]         @relation("Notification_recipient")
  sentNotifications     Notification[]         @relation("Notification_sender")
  answers               OnboardingAnswer[]
  reportsGiven          Report[]               @relation("Report_reporter")
  users                 User[]                 @relation("CouplePartners")

  @@index([coupleId])
  @@index([locationCity, isProfileComplete])
  @@map("couples")
}

model OnboardingAnswer {
  id                String   @id @default(cuid()) @map("_id")
  coupleId          String
  questionId        String
  selectedOptionIds String[]
  couple            Couple   @relation(fields: [coupleId], references: [coupleId])

  @@map("onboarding_answers")
}

model Community {
  id            String                 @id @default(cuid()) @map("_id")
  name          String                 @unique
  description   String?
  city          String
  coverImageUrl String?
  maxMembers    Int                    @default(50)
  tags          String[]               @default([])
  createdAt     DateTime               @default(now())
  updatedAt     DateTime               @updatedAt
  admins        CommunityAdmin[]
  joinRequests  CommunityJoinRequest[]
  members       CommunityMember[]
  messages      Message[]

  @@index([city])
  @@map("communities")
}

model CommunityMember {
  id          String    @id @default(cuid()) @map("_id")
  communityId String
  coupleId    String
  community   Community @relation(fields: [communityId], references: [id])
  couple      Couple    @relation(fields: [coupleId], references: [coupleId])

  @@unique([communityId, coupleId])
  @@index([coupleId])
  @@map("community_members")
}

model CommunityAdmin {
  id          String    @id @default(cuid()) @map("_id")
  communityId String
  coupleId    String
  community   Community @relation(fields: [communityId], references: [id])
  couple      Couple    @relation(fields: [coupleId], references: [coupleId])

  @@unique([communityId, coupleId])
  @@index([coupleId])
  @@map("community_admins")
}

model CommunityJoinRequest {
  id          String    @id @default(cuid()) @map("_id")
  communityId String
  coupleId    String
  community   Community @relation(fields: [communityId], references: [id])
  couple      Couple    @relation(fields: [coupleId], references: [coupleId])

  @@unique([communityId, coupleId])
  @@index([coupleId])
  @@map("community_join_requests")
}

model Match {
  id         String      @id @default(cuid()) @map("_id")
  couple1Id  String
  couple2Id  String
  actionById String
  status     MatchStatus
  matchScore Float       @default(0)
  insights   String[]    @default([])
  createdAt  DateTime    @default(now())
  updatedAt  DateTime    @updatedAt
  actionBy   Couple      @relation("Match_actionBy", fields: [actionById], references: [coupleId])
  couple1    Couple      @relation("Match_couple1", fields: [couple1Id], references: [coupleId])
  couple2    Couple      @relation("Match_couple2", fields: [couple2Id], references: [coupleId])
  messages   Message[]   @relation("Message_privateChat")

  @@unique([couple1Id, couple2Id])
  @@index([couple2Id, status])
  @@index([couple1Id, status])
  @@index([status])
  @@index([createdAt])
  @@map("matches")
}

model Message {
  id                   String      @id @default(cuid()) @map("_id")
  chatType             ChatType
  matchId              String?
  communityId          String?
  senderId             String
  senderUserId         String?
  senderName           String
  senderIndividualName String?
  content              String
  contentType          ContentType @default(text)
  audioDuration        Int?
  repliedToId          String?
  repliedToText        String?
  repliedToName        String?
  readBy               String[]    @default([])
  createdAt            DateTime    @default(now())
  updatedAt            DateTime    @updatedAt
  community            Community?  @relation(fields: [communityId], references: [id])
  match                Match?      @relation("Message_privateChat", fields: [matchId], references: [id])
  sender               Couple      @relation("Message_sender", fields: [senderId], references: [coupleId])
  senderUser           User?       @relation("Message_senderUser", fields: [senderUserId], references: [id])

  @@index([matchId, createdAt])
  @@index([communityId, createdAt])
  // Speeds up unread-count queries that filter by senderId within a chat.
  @@index([matchId, senderId])
  @@index([communityId, senderId])
  @@map("messages")
}

model Notification {
  id          String           @id @default(cuid()) @map("_id")
  recipientId String
  senderId    String?
  type        NotificationType
  title       String
  message     String
  data        Json?
  read        Boolean          @default(false)
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt
  recipient   Couple           @relation("Notification_recipient", fields: [recipientId], references: [coupleId])
  sender      Couple?          @relation("Notification_sender", fields: [senderId], references: [coupleId])

  @@index([recipientId, read])
  @@index([recipientId, type])
  @@index([createdAt])
  // Speeds up upsertMatchPending/Connected queries that filter by senderId+type.
  @@index([senderId, type])
  @@map("notifications")
}

model OtpToken {
  id        String   @id @default(cuid()) @map("_id")
  phone     String
  coupleId  String
  otpCode   String
  expiresAt DateTime
  attempts  Int      @default(0)
  createdAt DateTime @default(now())

  @@index([phone])
  @@index([phone, coupleId])
  @@map("otp_tokens")
}

model Prompt {
  id        String   @id @default(cuid()) @map("_id")
  text      String   @unique
  category  String   @default("chat_shortcut")
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("prompts")
}

model Report {
  id         String       @id @default(cuid()) @map("_id")
  reporterId String
  targetId   String
  reason     String
  details    String?
  status     ReportStatus @default(pending)
  createdAt  DateTime     @default(now())
  updatedAt  DateTime     @updatedAt
  reporter   Couple       @relation("Report_reporter", fields: [reporterId], references: [coupleId])

  @@map("reports")
}

enum UserRole {
  primary
  partner
  admin
}

enum MatchStatus {
  pending
  accepted
  rejected
  skipped
}

enum ChatType {
  private
  group
}

enum ContentType {
  text
  image
  gif
  prompt
  audio
}

enum NotificationType {
  match
  message
  community
  system
  admin
  nearby
}

enum ReportStatus {
  pending
  reviewed
  resolved
  dismissed
}
